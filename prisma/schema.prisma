// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  brand
  admin
  influencer
}

enum SurveySource {
  creating_new
  use_existing_survey
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  phoneNumber String?
  company     String?
  fullName    String
  countryCode String?
  password    String
  role        UserRole @default(brand)
  isApproved  Boolean  @default(true) // Influencers start as false, others as true
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  campaigns   Campaign[]
  surveys     Survey[]

  @@map("users")
}

model Campaign {
  id                String           @id @default(cuid())
  campaignName      String
  description       String
  surveySource      SurveySource     // creating_new | use_existing_survey (for reference)
  targetAudience    Json // Stores region, city, age, interest with "all"/"custom" and values arrays
  totalVoteNeeded   Int
  startDate         DateTime
  endDate           DateTime?
  isActive          Boolean          @default(true)
  isCompleted       Boolean          @default(false)
  numberOfInfluencer Int             @default(0)
  userId            String
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  surveys           Survey[]
  surveyResponses   SurveyResponse[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@map("campaigns")
}

model Survey {
  id               String           @id @default(cuid())
  title            String?
  questions        Json // Array of question objects: multiple-choice, yes-no, rating-scale, text
  campaignId       String
  campaign         Campaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  userId           String
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  surveyResponses  SurveyResponse[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@map("surveys")
}

model SurveyResponse {
  id         String   @id @default(cuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  surveyId   String
  survey     Survey   @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  userId     String?
  answers    Json?    // Stores question answers
  createdAt  DateTime @default(now())

  @@map("survey_responses")
}

model BudgetConfig {
  id               String   @id @default(cuid())
  key              String   @unique @default("default") // Singleton key for app-wide config
  pricePerUnitVote Decimal  @db.Decimal(10, 2) // Price per single vote
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("budget_configs")
}